{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus (Mimir)",
      "description": "Grafana Mimir / Prometheus data source",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "row", "name": "Row", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "Agent Mesh — end-to-end observability: request flow, security gates, A2A transport, LLM metrics",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100, "title": "Traffic", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "reqps"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "blocked" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "error" },   "properties": [{ "id": "color", "value": { "fixedColor": "red",    "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "success" }, "properties": [{ "id": "color", "value": { "fixedColor": "green",  "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (status) (rate(mesh_request_total[$__rate_interval]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "title": "Request Rate by Status",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "reqps" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (stage) (rate(mesh_request_blocked_total[$__rate_interval]))",
          "legendFormat": "{{stage}}",
          "refId": "A"
        }
      ],
      "title": "Blocked Request Rate by Stage",
      "type": "timeseries"
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101, "title": "Latency", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "ms" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 3,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum by (domain, le) (rate(mesh_request_duration_ms_bucket[$__rate_interval])))",
          "legendFormat": "p95 {{domain}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.50, sum by (domain, le) (rate(mesh_request_duration_ms_bucket[$__rate_interval])))",
          "legendFormat": "p50 {{domain}}",
          "refId": "B"
        }
      ],
      "title": "Request Duration by Domain (p50/p95)",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "ms" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 4,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum by (node, le) (rate(mesh_a2a_duration_ms_bucket[$__rate_interval])))",
          "legendFormat": "p95 {{node}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.50, sum by (node, le) (rate(mesh_a2a_duration_ms_bucket[$__rate_interval])))",
          "legendFormat": "p50 {{node}}",
          "refId": "B"
        }
      ],
      "title": "A2A Call Duration by Node (p50/p95)",
      "type": "timeseries"
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 102, "title": "Security Gates", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 19 },
      "id": 5,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (category) (rate(mesh_guardrail_block_total[$__rate_interval]))",
          "legendFormat": "{{category}}",
          "refId": "A"
        }
      ],
      "title": "Guardrail Blocks by Category",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 19 },
      "id": 6,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (domain, role) (rate(mesh_access_denied_total[$__rate_interval]))",
          "legendFormat": "{{domain}} / {{role}}",
          "refId": "A"
        }
      ],
      "title": "RBAC Access Denials by Domain + Role",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 19 },
      "id": 7,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (domain) (rate(mesh_compliance_fail_total[$__rate_interval]))",
          "legendFormat": "{{domain}}",
          "refId": "A"
        }
      ],
      "title": "Compliance Gate Failures by Domain",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "approved" }, "properties": [{ "id": "color", "value": { "fixedColor": "green",  "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "denied"   }, "properties": [{ "id": "color", "value": { "fixedColor": "red",    "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 19 },
      "id": 8,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (outcome) (rate(mesh_payment_gate_total[$__rate_interval]))",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ],
      "title": "Payment Gate Decisions",
      "type": "timeseries"
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "id": 103, "title": "A2A Transport Health", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "id": 9,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (node) (rate(mesh_a2a_error_total[$__rate_interval]))",
          "legendFormat": "{{node}}",
          "refId": "A"
        }
      ],
      "title": "A2A Error Rate by Node",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "id": 10,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (node) (rate(mesh_a2a_duration_ms_count{status=\"success\"}[$__rate_interval]))",
          "legendFormat": "{{node}}",
          "refId": "A"
        }
      ],
      "title": "A2A Successful Call Rate by Node",
      "type": "timeseries"
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 },
      "id": 104, "title": "LLM / Framework Metrics (SDK auto-instrumented)", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 37 },
      "id": 11,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (gen_ai_token_type) (rate(gen_ai_client_token_usage_total[$__rate_interval]))",
          "legendFormat": "{{gen_ai_token_type}}",
          "refId": "A"
        }
      ],
      "title": "LLM Token Usage Rate (input + completion)",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "ms" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 37 },
      "id": 12,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(gen_ai_client_operation_duration_bucket[$__rate_interval]))) * 1000",
          "legendFormat": "p95 LLM op",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.50, sum by (le) (rate(gen_ai_client_operation_duration_bucket[$__rate_interval]))) * 1000",
          "legendFormat": "p50 LLM op",
          "refId": "B"
        }
      ],
      "title": "LLM Operation Duration (p50/p95)",
      "type": "timeseries"
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 45 },
      "id": 200, "title": "Business KPIs", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 90 },
            { "color": "green", "value": 95 }
          ]},
          "unit": "percent", "min": 0, "max": 100
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 46 },
      "id": 201,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "100 * sum(rate(mesh_request_total{status=\"success\"}[$__rate_interval])) / sum(rate(mesh_request_total[$__rate_interval]))",
        "legendFormat": "Success Rate", "refId": "A"
      }],
      "title": "Request Success Rate %",
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 5 },
            { "color": "red", "value": 15 }
          ]},
          "unit": "percent", "min": 0, "max": 100
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 46 },
      "id": 202,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "100 * sum(rate(mesh_request_total{status=\"blocked\"}[5m])) / sum(rate(mesh_request_total[5m]))",
        "legendFormat": "Block Rate", "refId": "A"
      }],
      "title": "Security Block Rate %",
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 70 },
            { "color": "green", "value": 85 }
          ]},
          "unit": "percent", "min": 0, "max": 100
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 46 },
      "id": 203,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "100 * sum(rate(mesh_payment_gate_total{outcome=\"approved\"}[5m])) / sum(rate(mesh_payment_gate_total[5m]))",
        "legendFormat": "Approval Rate", "refId": "A"
      }],
      "title": "Payment Approval Rate %",
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 10000 },
            { "color": "red", "value": 30000 }
          ]},
          "unit": "ms"
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 46 },
      "id": 204,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "histogram_quantile(0.95, sum by (le) (rate(mesh_request_duration_ms_bucket[$__rate_interval])))",
        "legendFormat": "P95 Latency", "refId": "A"
      }],
      "title": "P95 Request Latency",
      "type": "stat"
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 52 },
      "id": 210, "title": "Domain & Role Analytics", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" } },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 53 },
      "id": 211,
      "options": { "pieType": "pie", "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
