      "gridPos": { "h": 8, "w": 5, "x": 5, "y": 62 },
      "id": 222,
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "sum by (domain, role) (rate(mesh_access_denied_total[$__rate_interval]))",
        "legendFormat": "{{domain}} / {{role}}", "refId": "A"
      }],
      "title": "RBAC Denials by Domain + Role",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "short" } },
      "gridPos": { "h": 8, "w": 5, "x": 10, "y": 62 },
      "id": 223,
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "sum by (domain) (rate(mesh_compliance_fail_total[$__rate_interval]))",
        "legendFormat": "{{domain}}", "refId": "A"
      }],
