      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 53 },
      "id": 212,
      "options": { "pieType": "donut", "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
