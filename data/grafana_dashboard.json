    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "short" } },
      "gridPos": { "h": 8, "w": 4, "x": 20, "y": 62 },
      "id": 225,
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "sum by (stage) (rate(mesh_request_blocked_total[$__rate_interval]))",
        "legendFormat": "{{stage}}", "refId": "A"
      }],
