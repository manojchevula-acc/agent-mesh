    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "ms" } },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 53 },
      "id": 213,
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "histogram_quantile(0.95, sum by (domain, le) (rate(mesh_request_duration_ms_bucket[$__rate_interval])))",
        "legendFormat": "p95 {{domain}}", "refId": "A"
      }],
      "title": "Domain Latency Comparison (p95)",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "stacking": { "mode": "normal" } }, "unit": "short" } },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 53 },
      "id": 214,
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
