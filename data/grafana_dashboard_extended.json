{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus (Mimir)",
      "description": "Grafana Mimir / Prometheus data source",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana",    "id": "grafana",    "name": "Grafana",    "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel",      "id": "timeseries", "name": "Time series","version": "" },
    { "type": "panel",      "id": "stat",       "name": "Stat",       "version": "" },
    { "type": "panel",      "id": "row",        "name": "Row",        "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "Agent Mesh — extended metrics: router analytics, memory/context depth, human-in-loop wait times, FinOps token & cost, AI safety (hallucination), tool authorization",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "Core Dashboard",
      "type": "dashboard",
      "url": "/d/agent-mesh-overview",
      "tooltip": "Agent Mesh — Observability Overview (core 24 panels)"
    }
  ],
  "panels": [

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 300, "title": "Router Analytics", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Average number of domains the Gateway resolved per request. Value of 1 = single-domain; 2+ = multi-domain decomposition triggered.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short",
          "decimals": 2
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "id": 301,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(mesh_router_domains_sum[$__rate_interval]) / rate(mesh_router_domains_count[$__rate_interval])",
          "legendFormat": "avg domains (all roles)",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (role) (rate(mesh_router_domains_sum[$__rate_interval])) / sum by (role) (rate(mesh_router_domains_count[$__rate_interval]))",
          "legendFormat": "avg domains ({{role}})",
          "refId": "B"
        }
      ],
      "title": "Avg Domains per Request",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Total routing decisions per second. Compare against mesh_request_total to understand what fraction of requests trigger multi-domain decomposition.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "id": 302,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(mesh_router_domains_count[$__rate_interval]))",
          "legendFormat": "routing decisions/s",
          "refId": "A"
        }
      ],
      "title": "Routing Decision Rate",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Rate of Gateway keyword-fallback activations — fires when the LLM produces an unparseable routing token and the system falls back to keyword heuristics. Spikes indicate model output quality degradation.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short"
        },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": ".*" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "id": 303,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (role) (rate(mesh_router_fallback_total[$__rate_interval]))",
          "legendFormat": "fallback ({{role}})",
          "refId": "A"
        }
      ],
      "title": "Router Fallback Rate (LLM unparseable)",
      "type": "timeseries"
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 310, "title": "Memory & Context Depth", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Distribution of session message counts at each append. High p95 values indicate deep context histories that consume significant token budget.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 10 },
      "id": 311,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(mesh_memory_messages_bucket[$__rate_interval])))",
          "legendFormat": "p95 messages",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.50, sum by (le) (rate(mesh_memory_messages_bucket[$__rate_interval])))",
          "legendFormat": "p50 messages",
          "refId": "B"
        }
      ],
      "title": "Session Message Depth (p50 / p95)",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Distribution of total context size in characters. Divide by 4 for a rough token estimate (~4 chars per token). High values risk hitting model context limits.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short",
          "displayName": "${__series.name} chars"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 10 },
      "id": 312,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(mesh_memory_context_chars_bucket[$__rate_interval])))",
          "legendFormat": "p95 chars",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.50, sum by (le) (rate(mesh_memory_context_chars_bucket[$__rate_interval])))",
          "legendFormat": "p50 chars",
          "refId": "B"
        }
      ],
      "title": "Context Size in Chars (p50 / p95)",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Rolling average context size in characters. Useful for trending — a rising average indicates sessions are growing longer over time.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 10 },
      "id": 313,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(mesh_memory_context_chars_sum[$__rate_interval]) / rate(mesh_memory_context_chars_count[$__rate_interval])",
          "legendFormat": "avg context chars",
          "refId": "A"
        }
      ],
      "title": "Avg Context Size over Time",
      "type": "timeseries"
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 320, "title": "Human-in-the-Loop — Approval Wait Time", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Distribution of time from payment approval prompt display to human decision. High p99 may indicate approver fatigue or an unattended console.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "ms"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 19 },
      "id": 321,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(mesh_approval_wait_ms_bucket[$__rate_interval])))",
          "legendFormat": "p99",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(mesh_approval_wait_ms_bucket[$__rate_interval])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.50, sum by (le) (rate(mesh_approval_wait_ms_bucket[$__rate_interval])))",
          "legendFormat": "p50",
          "refId": "C"
        }
      ],
      "title": "Approval Wait Time (p50 / p95 / p99)",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Approval wait time at p95 sliced by decision outcome. Comparing approved vs denied wait times reveals whether denials are quick (instant rejection) or slow (deliberation).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "ms"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "approved" }, "properties": [{ "id": "color", "value": { "fixedColor": "green",  "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "denied"   }, "properties": [{ "id": "color", "value": { "fixedColor": "red",    "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 19 },
      "id": 322,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum by (outcome, le) (rate(mesh_approval_wait_ms_bucket[$__rate_interval])))",
          "legendFormat": "p95 ({{outcome}})",
          "refId": "A"
        }
      ],
      "title": "Approval Wait Time by Outcome (p95)",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Current p95 approval wait time. Green = under 30 s, Yellow = 30–120 s, Red = over 2 min (approver likely unresponsive).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 30000 },
              { "color": "red",    "value": 120000 }
            ]
          },
          "unit": "ms",
          "mappings": []
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 19 },
      "id": 323,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(mesh_approval_wait_ms_bucket[5m])))",
          "legendFormat": "P95 Approval Wait",
          "refId": "A"
        }
      ],
      "title": "Approval Wait P95 (current)",
      "type": "stat"
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "id": 330, "title": "FinOps — Token Usage & Cost", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Custom mesh token consumption rate broken down by call_type (a2a / tool / direct) and direction (input / output). Complements the framework gen_ai.client.token.usage metric.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 28 },
      "id": 331,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (call_type, direction) (rate(mesh_token_usage_total[$__rate_interval]))",
          "legendFormat": "{{call_type}} / {{direction}}",
          "refId": "A"
        }
      ],
      "title": "Token Usage Rate by Call Type + Direction",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Token consumption rate grouped by model name. Useful when multiple models are configured to understand per-model spend.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 28 },
      "id": 332,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (model) (rate(mesh_token_usage_total[$__rate_interval]))",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "title": "Token Usage Rate by Model",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Estimated per-invocation LLM serving cost (USD). Calculated from token counts × pricing config in .env. Defaults to $0 for self-hosted Ollama.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "currencyUSD",
          "decimals": 6
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 28 },
      "id": 333,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(mesh_cost_estimated_usd_bucket[$__rate_interval])))",
          "legendFormat": "p95 cost/req",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.50, sum by (le) (rate(mesh_cost_estimated_usd_bucket[$__rate_interval])))",
          "legendFormat": "p50 cost/req",
          "refId": "B"
        }
      ],
      "title": "Estimated Cost per Request (p50 / p95)",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "p95 estimated cost broken down by domain — identify which domains are most expensive to serve.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "currencyUSD",
          "decimals": 6
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 36 },
      "id": 334,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum by (domain, le) (rate(mesh_cost_estimated_usd_bucket[$__rate_interval])))",
          "legendFormat": "p95 ({{domain}})",
          "refId": "A"
        }
      ],
      "title": "Estimated Cost by Domain (p95)",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Running rate of total estimated cost in USD per second. Multiply by 3600 for hourly cost estimate.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.001 },
              { "color": "red",    "value": 0.01 }
            ]
          },
          "unit": "currencyUSD",
          "decimals": 8
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 36 },
      "id": 335,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(mesh_cost_estimated_usd_sum[$__rate_interval]))",
          "legendFormat": "USD/s",
          "refId": "A"
        }
      ],
      "title": "Total Estimated Cost Rate (USD/s)",
      "type": "stat"
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 44 },
      "id": 340, "title": "AI Safety & Quality — Hallucination Detection", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Rate of responses flagged by the speculation-phrase heuristic (mesh.hallucination.suspected). Each event indicates a response containing uncertainty markers like 'I think', 'probably', 'I'm not sure'. Per FAB AI/Model Risk Policy, these should be investigated.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short"
        },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": ".*" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 45 },
      "id": 341,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (domain) (rate(mesh_hallucination_suspected_total[$__rate_interval]))",
          "legendFormat": "{{domain}}",
          "refId": "A"
        }
      ],
      "title": "Hallucination Suspected Rate by Domain",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Hallucination flags broken down by heuristic indicator. Currently the only value is 'speculation_phrase' (regex match). Future NLP classifiers would add additional indicator labels.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 45 },
      "id": 342,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (indicator) (rate(mesh_hallucination_suspected_total[$__rate_interval]))",
          "legendFormat": "{{indicator}}",
          "refId": "A"
        }
      ],
      "title": "Hallucination Flags by Indicator",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Total hallucination flags in the last hour. Any non-zero value should be investigated. Per FAB AI/Model Risk Policy, suspected outputs require human review before being relied upon.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red",   "value": 1 }
            ]
          },
          "unit": "short",
          "mappings": [
            { "type": "value", "options": { "0": { "text": "NONE", "color": "green" } } }
          ]
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 45 },
      "id": 343,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(increase(mesh_hallucination_suspected_total[1h]))",
          "legendFormat": "flags (1h)",
          "refId": "A"
        }
      ],
      "title": "Hallucination Flags (last 1h)",
      "type": "stat"
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 53 },
      "id": 350, "title": "Tool Authorization", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Tool-level authorization decisions (allowed vs denied) by tool name. Tracks which tools are being invoked and refused, revealing access pattern anomalies.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short"
        },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": ".*denied.*" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byRegexp", "options": ".*allowed.*" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 54 },
      "id": 351,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (tool, outcome) (rate(mesh_tool_access_total[$__rate_interval]))",
          "legendFormat": "{{tool}} / {{outcome}}",
          "refId": "A"
        }
      ],
      "title": "Tool Access Decisions by Tool",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Rate of tool access denials per user role. A spike for a low-privilege role attempting a leadership-only tool (e.g. issue_payment) may indicate privilege escalation attempts.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 54 },
