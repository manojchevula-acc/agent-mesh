FROM python:3.11-slim

WORKDIR /app

# Install system deps for torch / FlagEmbedding
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl build-essential libgl1 && rm -rf /var/lib/apt/lists/*

RUN pip install uv

COPY backend/pyproject.toml backend/uv.lock ./
RUN uv sync --frozen --no-dev

COPY backend/src/ ./src/
COPY backend/config/ ./config/

ENV PYTHONPATH=/app/src
ENV PYTHONUNBUFFERED=1

# Pre-download the BGE-M3 model into the image layer cache (optional; comment out
# to download lazily at runtime).
# RUN python -c "from FlagEmbedding import BGEM3FlagModel; BGEM3FlagModel('BAAI/bge-m3', use_fp16=True)"

EXPOSE 8000
CMD ["uvicorn", "gernas_rag.main:app", "--host", "0.0.0.0", "--port", "8000", "--workers", "1"]
