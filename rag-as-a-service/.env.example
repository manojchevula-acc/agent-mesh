# ── Streamlit UI ──────────────────────────────────────────────────────────
STREAMLIT_API_BASE=http://localhost:8000
# STREAMLIT_API_KEY falls back to API_KEY below — no need to set separately

# ── Service ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG

# ── API auth ──────────────────────────────────────────────────────────────
API_KEY=dev-secret-key-change-in-production
# JWT_SECRET=                       # Set for production JWT validation

# ── MCP search tool (mcp_integration/) ──────────────────────────────────────
# The MCP server reuses STREAMLIT_API_BASE + API_KEY above by default; override
# only if the tool should hit a different RAG host/key:
# RAG_API_URL=http://localhost:8000
# RAG_API_KEY=                       # falls back to API_KEY
RAG_GENERATE_ANSWER=false           # true → tool returns a full cited answer by default
# Transport: stdio (local, default) or http (network service for a remote agent):
# MCP_TRANSPORT=stdio               # stdio | http
# MCP_HOST=0.0.0.0                  # http bind host (use 0.0.0.0 to accept remote)
# MCP_PORT=9000                     # http port → tool served at http://HOST:PORT/mcp
# ANTHROPIC_API_KEY=sk-ant-XXXX     # required only for the example agent (agent.py)
# AGENT_MODEL=claude-sonnet-4-6     # Claude model used by agent.py

# ── LLM provider ──────────────────────────────────────────────────────────
RAG__LLM__PROVIDER=groq             # groq | anthropic | huggingface | openai_compat
RAG__LLM__MODEL_NAME=llama-3.3-70b-versatile
RAG__LLM__GROQ_API_KEY=gsk_XXXXXXXXXX
# RAG__LLM__ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXX
# RAG__LLM__OPENAI_BASE_URL=http://localhost:8080/v1

# ── Embedding model ───────────────────────────────────────────────────────
RAG__EMBEDDING__PROVIDER=bgem3      # bgem3 | sentence_transformer
RAG__EMBEDDING__MODEL_NAME=BAAI/bge-m3
RAG__EMBEDDING__DEVICE=cpu          # cpu | cuda | mps
RAG__EMBEDDING__USE_FP16=false
RAG__EMBEDDING__BATCH_SIZE=16
RAG__EMBEDDING__MAX_LENGTH=512
RAG__EMBEDDING__RETURN_SPARSE=true

# ── Vector DB ─────────────────────────────────────────────────────────────
RAG__VECTORDB__PROVIDER=qdrant      # qdrant | milvus | chromadb
RAG__VECTORDB__COLLECTION_NAME=fab_gernas_docs
# Local embedded mode (no server/Docker needed):
RAG__VECTORDB__QDRANT_PATH=./qdrant_storage
# Server mode:
# RAG__VECTORDB__QDRANT_URL=http://localhost:6333
# RAG__VECTORDB__MILVUS_HOST=localhost
# RAG__VECTORDB__CHROMA_PATH=./chroma_db

# ── Chunking ──────────────────────────────────────────────────────────────
RAG__CHUNKING__STRATEGY=hierarchical          # hierarchical | fixed_size
RAG__CHUNKING__EXTRACTION_STRATEGY=auto       # auto | docling | unstructured | pymupdf
RAG__CHUNKING__CHUNK_SIZE=400
RAG__CHUNKING__CHUNK_OVERLAP=64
RAG__CHUNKING__MIN_CHUNK_SIZE=80
RAG__CHUNKING__MAX_CHUNK_SIZE=600
RAG__CHUNKING__ENABLE_PARENT_CHUNKS=true
RAG__CHUNKING__PARENT_CHUNK_SIZE=1500

# ── Retrieval ─────────────────────────────────────────────────────────────
RAG__RETRIEVAL__DENSE_TOP_K=40
RAG__RETRIEVAL__SPARSE_TOP_K=40
RAG__RETRIEVAL__RRF_K=60
RAG__RETRIEVAL__PRE_RERANK_TOP_K=20
RAG__RETRIEVAL__FINAL_TOP_K=3
RAG__RETRIEVAL__FRESHNESS_PENALTY_ENABLED=true
RAG__RETRIEVAL__INCLUDE_PARENT_CHUNKS=true

# ── Ingestion ─────────────────────────────────────────────────────────────
RAG__INGESTION__MAX_CONCURRENT_DOCUMENTS=1

# ── Evaluation ────────────────────────────────────────────────────────────
# RAGAS judge backend: 'groq' (hosted) | 'ollama' (local) | 'openai'
# Ollama (local, no API key needed):
# RAG__EVALUATION__JUDGE_PROVIDER=ollama
# RAG__EVALUATION__JUDGE_MODEL=llama3.2:3b
# RAG__EVALUATION__JUDGE_BASE_URL=http://localhost:11434/v1
RAG__EVALUATION__JUDGE_PROVIDER=groq
RAG__EVALUATION__JUDGE_MODEL=llama-3.3-70b-versatile
RAG__EVALUATION__JUDGE_MAX_TOKENS=1024
RAG__EVALUATION__JUDGE_MAX_WORKERS=1
RAG__EVALUATION__JUDGE_MAX_RETRIES=15
RAG__EVALUATION__JUDGE_MAX_WAIT=90
RAG__EVALUATION__JUDGE_TIMEOUT_SECONDS=900
RAG__EVALUATION__MAX_CONTEXT_CHARS=6000
RAG__EVALUATION__SINGLE_ANSWER_MAX_CONTEXT_CHARS=6000
# Fallback embeddings model for standalone evaluation scripts
RAG__EVALUATION__EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_CACHE_TTL_SECONDS=900
REDIS_ENABLED=false
