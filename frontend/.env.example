# ── Agent Mesh Frontend configuration ─────────────────────────────────────────
# Copy to `.env` and adjust. All Vite client env vars MUST be prefixed VITE_.

# Base URL of the Starlette API server (api_server.py).
# In development the Vite dev server proxies /api and /health to this target
# (see vite.config.ts), so requests stay same-origin and CORS is a non-issue.
VITE_API_BASE_URL=http://localhost:8000

# When true (default in dev), requests use the Vite proxy (same-origin).
# Set to false to call VITE_API_BASE_URL directly from the browser, which
# requires the Starlette CORSMiddleware to allow this origin.
VITE_USE_PROXY=true
