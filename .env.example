# ── GERNAS RAG Frontend configuration ────────────────────────────────────────
# Copy to `.env` and adjust. All Vite client env vars MUST be prefixed VITE_.

# Base URL of the FastAPI backend.
# In development the Vite dev server proxies /api, /health and /ready to this
# target (see vite.config.ts), so requests stay same-origin and CORS is a non-issue.
VITE_API_BASE_URL=http://localhost:8000

# API key sent as the X-API-Key header. Must match API_KEY in the backend .env.
# NOTE: anything in a VITE_ var is bundled into client JS and visible to the
# browser. For a hardened production deployment, terminate auth at a reverse
# proxy / BFF instead of shipping the key to the client.
VITE_API_KEY=dev-secret-key-change-in-production

# When true (default in dev), requests are sent to same-origin paths and rely on
# the Vite proxy. Set to false to call VITE_API_BASE_URL directly (requires the
# backend CORS to allow this origin).
VITE_USE_PROXY=true
