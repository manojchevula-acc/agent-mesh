# ==============================================================================
# Microsoft Agent Framework Demo Configuration
# ==============================================================================

# Ollama LLM Configuration (Local Ollama LLM)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Storage Configuration
POLICIES_FILE=data/policies.json
AUDIT_LOG_FILE=data/audit_trail.jsonl
CONVERSATION_STORE_DIR=data/conversations

# ==============================================================================
# Observability (Microsoft Agent Framework-native OpenTelemetry + logging)
# ==============================================================================
# OBS_PROFILE selects exporter wiring:
#   dev  -> framework OTel providers (console + OTLP, e.g. Aspire/Jaeger)
#   prod -> Azure Monitor / Application Insights
#   off  -> file logging only (no OTel providers)
OBS_PROFILE=dev

# Agent Framework standard OpenTelemetry switches (read by configure_otel_providers).
ENABLE_INSTRUMENTATION=true
# Only enable in dev/test — captures prompts, responses, tool args/results in spans.
ENABLE_SENSITIVE_DATA=true
# Print spans/metrics to stdout (handy without a collector).
ENABLE_CONSOLE_EXPORTERS=true

# OTLP exporter target (dev). Aspire Dashboard / Jaeger / Grafana Tempo, etc.
#   Aspire: docker run --rm -it -p 18888:18888 -p 4317:18889 \
#             mcr.microsoft.com/dotnet/aspire-dashboard:latest
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
# Per-process name is set programmatically (agent_mesh_<node>); this is the default.
OTEL_SERVICE_NAME=agent_mesh

# Azure Application Insights (OBS_PROFILE=prod):
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...;IngestionEndpoint=...

# ==============================================================================
# Grafana Cloud (OBS_PROFILE=grafana) — free tier, no local collector needed
# ==============================================================================
# Step 1: Sign up at https://grafana.com/auth/sign-up (free tier)
# Step 2: In your Grafana Cloud portal → your stack → Details
#         Copy the "Instance ID" (numeric, e.g. 123456) and note the region
#         in the OTLP endpoint URL (e.g. prod-us-east-0).
# Step 3: Go to Security → Service Accounts → Add service account token
#         (role: MetricsPublisher). Copy the token.
# Step 4: Set OBS_PROFILE=grafana and fill in the three vars below.
#
# OBS_PROFILE=grafana
# GRAFANA_OTLP_ENDPOINT=https://otlp-gateway-prod-us-east-0.grafana.net/otlp
# GRAFANA_INSTANCE_ID=123456
# GRAFANA_API_TOKEN=glc_eyJ...
#
# Grafana dashboard exploration after first run:
#   Traces:  Explore → datasource "Tempo"  → search service_name = agent_mesh_*
#   Metrics: Explore → datasource "Prometheus" → gen_ai_client_token_usage_total
#   Logs:    Explore → datasource "Loki" → label filter: service_name = agent_mesh

# Centralized application logging (durable, rotating, trace-correlated).
LOG_LEVEL=INFO
LOG_FILE=data/logs/agent_mesh.log
LOG_JSON=false
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# Legacy JSONL trace sink (data/trace_log.jsonl). Off by default: workflow/agent
# spans now cover the same telemetry. Set true only for offline debugging.
ENABLE_TRACE_JSONL=false

# ==============================================================================
# DevUI (Docker-free live trace + agent visualization)
# ==============================================================================
# `python devui_app.py` runs the whole mesh in ONE process so DevUI captures the
# full in-process trace tree (workflow -> executors -> agents -> tools). DevUI is
# a development-only tool — do not expose it as a production surface.
DEVUI_HOST=127.0.0.1
DEVUI_PORT=8090
# Identity stamped on DevUI requests (leadership avoids finance access blocks).
DEVUI_USER=devui
DEVUI_ROLE=leadership
DEVUI_AUTO_OPEN=true
# No-auth is honoured by DevUI on loopback hosts only.
DEVUI_NO_AUTH=true

